# Indexarr environment configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# User/Group configuration
# =============================================================================
# By default, Indexarr runs as 1000:1000 (UID:GID).
# If your media library is owned by a different user, indexarr may not have
# permission to read your media files, which can cause scan issues.
# In that case, you MUST set these values to match the owner:
#   - UID of the app user inside container (default is 1000)
#   - GID of the app user inside container (default is 1000)

UID=1000
GID=1000

# =============================================================================
# Media library host paths (Required)
# =============================================================================
# Paths on your host system where media libraries are located
# These must match the volume mounts in docker-compose.yml

MOVIES_HOST_PATH=/tmp/indexarr/movies
SERIES_HOST_PATH=/tmp/indexarr/series

# =============================================================================
# API keys (Required for metadata fetching in filesystem scanning mode)
# =============================================================================
# Get your API keys from:
#   - TMDB: https://www.themoviedb.org/settings/api
#   - TVDB: https://thetvdb.com/api-information

TMDB_API_KEY=your_tmdb_api_key_here
TVDB_API_KEY=your_tvdb_api_key_here

# =============================================================================
# External services (Optional but recommended for best experience)
# =============================================================================
# Radarr integration for importing movies
# If configured, movies will be imported from Radarr instead of filesystem scanning
RADARR_URL=http://radarr:7878
RADARR_API_KEY=

# Sonarr integration for importing TV series
# If configured, series will be imported from Sonarr instead of filesystem scanning
SONARR_URL=http://sonarr:8989
SONARR_API_KEY=

# Path mapping for Docker environments
# If Radarr/Sonarr sees files at a different path than Indexarr, use these to map them
# Format: "radarr_path:local_path" (e.g., "/movies:/data/movies")
RADARR_PATH_MAPPING=
SONARR_PATH_MAPPING=

# =============================================================================
# Library paths (for filesystem scanning)
# =============================================================================
# Used when Radarr/Sonarr are NOT configured
# You can configure:
#   - MOVIES_LIBRARY_PATHS: Paths to scan for movies only
#   - SERIES_LIBRARY_PATHS: Paths to scan for TV series only
#   - MEDIA_LIBRARY_PATHS: Fallback paths that scan both movies and series
MOVIES_LIBRARY_PATHS=
SERIES_LIBRARY_PATHS=
MEDIA_LIBRARY_PATHS=

# =============================================================================
# Scan configuration
# =============================================================================
# Comma-separated list of additional folder names to skip during scanning (optional)
SKIP_FOLDERS=Behind The Scenes, Deleted Scenes, Featurettes, Interviews, Scenes, Shorts, Trailers, Other

# Hours between automatic media library scans (default: 24)
SCAN_INTERVAL=24

# Maximum scan timeout in minutes (default: 30)
SCAN_TIMEOUT=30

# =============================================================================
# Timezone
# =============================================================================
# Set to your timezone (examples: Europe/Paris, America/New_York, UTC)
TZ=Europe/Paris

# =============================================================================
# Authentication (Optional)
# =============================================================================
# Authentication mode:
#   - none: No authentication required (default)
#   - simple: Username/password authentication with admin user from env vars
#   - oidc: OpenID Connect authentication (coming in a future release)
AUTH_MODE=none

# Simple auth configuration (required when AUTH_MODE=simple)
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=your_secure_password_here

# Session configuration
# Secret key for signing session tokens (auto-generated if not provided)
AUTH_SESSION_SECRET=
# Session duration in hours (default: 168 = 7 days)
AUTH_SESSION_MAX_AGE=168

# OIDC Configuration (required when AUTH_MODE=oidc)
# Issuer URL - the OIDC provider URL (e.g., Keycloak, Auth0, Google)
OIDC_ISSUER_URL=https://your-issuer.example.com/realms/your-realm
# Client ID and Secret from your OIDC provider
OIDC_CLIENT_ID=indexarr
OIDC_CLIENT_SECRET=your_client_secret_here
# Redirect URL - must match your OIDC provider configuration
# Format: https://your-indexarr-url/api/auth/oidc/callback
OIDC_REDIRECT_URL=http://localhost:8080/api/auth/oidc/callback
# OIDC scopes (default: openid,profile,email)
OIDC_SCOPES=openid,profile,email
# Admin role mapping - which claim to check for admin rights
# Common options: "groups", "roles", "realm_access.roles" (Keycloak), etc.
OIDC_ADMIN_CLAIM=groups
# Value in the admin claim that grants admin role
OIDC_ADMIN_VALUE=indexarr-admins
# Claim to use for username (default: preferred_username)
# Options: preferred_username, email, sub, name
OIDC_USERNAME_CLAIM=preferred_username
# Automatically create users on first OIDC login (default: true)
OIDC_AUTO_CREATE_USER=true
